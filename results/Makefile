VENV := .venv
PY_PDFS := 
TEX_PY_PDF := static-ipc-intro.pdf block-speed.pdf static-ipc.pdf baseline.pdf baseline2.pdf baseline3.pdf baseline4.pdf qos.pdf
TEX_PDF := 

all: $(PY_PDFS) $(TEX_PDF) $(TEX_PY_PDF)

# PDFs that are generated by running a Python script of the same basename
$(PY_PDFS): %.pdf: %.py | $(VENV)
	$(VENV)/bin/python $<

# The special one: build it however you need (example: from Markdown via pandoc)
# Adjust inputs/command to your real workflow.
$(TEX_PY_PDF): %.pdf: %.py %.tex | $(VENV)
	mkdir -p tmp
	$(VENV)/bin/python $<
	lualatex -interaction=nonstopmode -halt-on-error $*.tex

# The special one: build it however you need (example: from Markdown via pandoc)
# Adjust inputs/command to your real workflow.
$(TEX_PDF): %.pdf: %.tex 
	lualatex -interaction=nonstopmode -halt-on-error $*.tex

# Create venv once
$(VENV): requirements.txt
	@if [ ! -d $(VENV) ]; then \
		echo "Creating virtual environment..."; \
		python3 -m venv $(VENV); \
		$(VENV)/bin/pip install -r requirements.txt; \
	else \
		echo "Virtual environment already exists."; \
	fi

.PHONY: clean mrproper
clean:
	rm -f *.pdf
	rm -f *.aux *.log *.out *.toc *.synctex.gz *.fls *.fdb_latexmk *.dep *.dpth *.md5 *.auxlock
	rm -rf tmp

mrproper: clean
	rm -rf $(VENV)

